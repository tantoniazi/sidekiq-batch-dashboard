<div class="card border-0 shadow-sm h-100">
  <div class="card-body">
    <div class="d-flex justify-content-between align-items-start">
      <div>
        <p class="text-muted small text-uppercase mb-1"><%= @title %></p>
        <h3 class="mb-0"><%= @value %></h3>
        <% if @subtitle.present? %>
          <p class="text-muted small mb-0 mt-1"><%= @subtitle %></p>
        <% end %>
      </div>
      <% if @badge.present? %>
        <span class="badge bg-<%= @css_class %>"><%= @badge %></span>
      <% end %>
    </div>
  </div>
</div>
